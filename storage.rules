rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Product images
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Product videos
    match /product-videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Avatar images
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Avatar videos
    match /avatar-videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
