rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is a super admin.
    // Accepts either the `superAdmin: true` custom claim OR the hardcoded
    // initial-admin UID. Mirrors the dual check in functions/index.js so
    // rules and callable functions stay consistent.
    function isSuperAdmin() {
      return request.auth != null
        && (request.auth.token.superAdmin == true
            || request.auth.uid == "RnBej9HSStVJXA0rtIB02W0R1yv2");
    }

    // Helper: check if user is a viewer
    function isViewer() {
      return request.auth != null && request.auth.token.viewer == true;
    }

    // Helper: check if user owns the document (by vendorId)
    function isOwner() {
      return request.auth != null && resource.data.vendorId == request.auth.uid;
    }

    // Helper: check if user belongs to the document's class
    function isInProductClass() {
      return request.auth != null && request.auth.token.class == resource.data.class;
    }

    function isInAvatarClass() {
      return request.auth != null && request.auth.token.avatarClass == resource.data.class;
    }

    // Products
    match /products/{productId} {
      // Any authenticated user can read products in their class; admins and viewers can read all
      allow read: if request.auth != null;

      // Only the owner or super admin can update/delete
      // Only authenticated non-viewers can create (with their own vendorId)
      allow create: if request.auth != null
                    && !isViewer()
                    && request.resource.data.vendorId == request.auth.uid;
      allow update: if isOwner() || isSuperAdmin();
      allow delete: if isOwner() || isSuperAdmin();

      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        // Any authenticated non-viewer can write reviews
        allow create: if request.auth != null && !isViewer();
        // Only the review author or super admin can update/delete
        allow update, delete: if request.auth != null
                              && (resource.data.userId == request.auth.uid || isSuperAdmin());
      }
    }

    // Product classes - only super admin can write
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Avatars (Hirable Talent)
    match /avatars/{avatarId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && !isViewer()
                    && request.resource.data.vendorId == request.auth.uid;
      allow update: if isOwner() || isSuperAdmin();
      allow delete: if isOwner() || isSuperAdmin();

      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && !isViewer();
        allow update, delete: if request.auth != null
                              && (resource.data.userId == request.auth.uid || isSuperAdmin());
      }
    }

    // Avatar classes - only super admin can write
    match /avatar-classes/{classId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // School registrations (created by Stripe webhook)
    match /schools/{schoolId} {
      // Public school data (branding, subdomain) — readable by anyone
      allow read: if true;
      // Only server-side (webhook/API routes) can write
      allow write: if false;

      // Private school data (credentials, Stripe IDs) — server-only
      match /private/{docId} {
        allow read: if false;
        allow write: if false;
      }
    }

    // Per-student teacher notes & metadata (additive — no migration of existing data)
    match /students/{uid} {
      function isOwnRecord() {
        return request.auth != null && request.auth.uid == uid;
      }
      function teacherOwnsThisStudent() {
        return request.auth != null
          && (
            (request.auth.token.class != null
              && resource.data.class == request.auth.token.class)
            || (request.auth.token.avatarClass != null
              && resource.data.avatarClass == request.auth.token.avatarClass)
          );
      }

      allow read:   if isSuperAdmin() || isOwnRecord() || teacherOwnsThisStudent();
      allow create, update: if isSuperAdmin()
        || (request.auth != null
            && (
                (request.auth.token.class != null
                  && request.resource.data.class == request.auth.token.class)
                || (request.auth.token.avatarClass != null
                  && request.resource.data.avatarClass == request.auth.token.avatarClass)
            ));
      allow delete: if isSuperAdmin();
    }

    // Activity events — append-only audit log of teacher actions
    match /events/{eventId} {
      // Read: super admin always; teachers only see events from their school scope
      allow read: if isSuperAdmin()
        || (request.auth != null
            && (
              (request.auth.token.class != null
                && resource.data.school == request.auth.token.class)
              || (request.auth.token.avatarClass != null
                && resource.data.school == request.auth.token.avatarClass)
            ));

      // Create: any signed-in admin or teacher; the actor field must match the caller
      allow create: if request.auth != null
        && request.resource.data.actor == request.auth.uid
        && request.resource.data.createdAt == request.time;

      // Events are append-only — no updates or deletes
      allow update, delete: if false;
    }
  }
}
